# Конфигурация для Docker-окружения
# Скопируйте этот файл как .env в корне перед запуском docker-compose

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# База данных PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=agency_db

# pgAdmin
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# Python Agent
OLLAMA_HOST=ollama:11434
SEARXNG_URL=http://searxng:8080
ORCHESTRATOR_URL=http://orchestrator:8080
MODEL_NAME=qwen2.5:1.5b

# LLM Provider Configuration (ollama or openrouter)
# LLM_PROVIDER=ollama
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/elephant-alpha
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
# OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
# OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
FALLBACK_TO_OLLAMA=false

# Go Orchestrator
AGENT_URL=http://agent:5000/enqueue
SERVER_PORT=8080

# Разрешенные пользователи Telegram (через запятую)
ALLOWED_USER_IDS=1159881767