# Пример конфигурации для Go-оркестратора
# В Docker-окружении эти переменные будут переопределены через docker-compose

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=agency_db
AGENT_URL=http://localhost:5000/enqueue
SERVER_PORT=8080
ALLOWED_USER_IDS=123456789

# Agent endpoints (можно задать через переменные)
AGENT_SCOUT_URL=http://agent-scout:5000/enqueue
AGENT_ANALYST_URL=http://agent-analyst:5000/enqueue
AGENT_WRITER_URL=http://agent-writer:5000/enqueue
AGENT_CRITIC_URL=http://agent-critic:5000/enqueue